# ============================================================================
# خوارزميات (Khawarizmiat) — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم
# ============================================================================

# ── Django Core ────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL 16) ───────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/khawarizmiat_dev

# ── Cache / Celery (Redis) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Email (Development uses console) ───────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@khawarizmiat.com

# ── reCAPTCHA v3 (https://www.google.com/recaptcha/admin) ──────────────────
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_REQUIRED_SCORE=0.5

# ── Telegram Bot (https://t.me/BotFather) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Cloudinary (https://cloudinary.com) ────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Sentry (https://sentry.io) ─────────────────────────────────────────────
SENTRY_DSN=

# ── Plausible Analytics ────────────────────────────────────────────────────
PLAUSIBLE_DOMAIN=khawarizmiat.com

# ── Production Only ────────────────────────────────────────────────────────
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
